# Sao chép file này thành .env rồi chỉnh giá trị: cp .env.example .env
# (.env đã nằm trong .gitignore — không bao giờ commit mật khẩu thật)

# ── Server ───────────────────────────────────────────────────────
# Cổng HTTP
PORT=3000

# Đường dẫn file SQLite (dùng :memory: để chạy không lưu file)
DB_PATH=data/rental.db

# Thư mục frontend đã build — mặc định tự tìm client/dist, thường không cần đổi
# CLIENT_DIR=client/dist

# ── Đăng nhập ────────────────────────────────────────────────────
# Tài khoản chủ trọ — BẮT BUỘC đổi khi deploy thật (mặc định admin/admin)
AUTH_USERNAME=admin
AUTH_PASSWORD=doi-mat-khau-nay

# Secret ký token đăng nhập (hạn 7 ngày).
# Đặt một chuỗi ngẫu nhiên dài và CỐ ĐỊNH — không đặt thì mỗi lần restart
# server sẽ phải đăng nhập lại. Tạo nhanh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=thay-bang-chuoi-ngau-nhien-dai
